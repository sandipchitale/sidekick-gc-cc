{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "start-sidekick-session",
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/sidekick.ts claude-code-sidekick"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "prompt",
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/sidekick.ts claude-code-sidekick"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "prompt",
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/sidekick.ts claude-code-sidekick"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "end-sidekick-session",
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/sidekick.ts claude-code-sidekick"
          }
        ]
      }
    ]
  }
}
