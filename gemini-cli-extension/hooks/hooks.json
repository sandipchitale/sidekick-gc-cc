{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "name": "start-sidekick-session",
            "type": "command",
            "command": "node ${extensionPath}/scripts/sidekick.ts gemini-cli-sidekick"
          }
        ]
      }
    ],
    "BeforeModel": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "send-prompt-to-sidekick",
            "type": "command",
            "command": "node ${extensionPath}/scripts/sidekick.ts gemini-cli-sidekick"
          }
        ]
      }
    ],
    "AfterModel": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "send-response-to-sidekick",
            "type": "command",
            "command": "node ${extensionPath}/scripts/sidekick.ts gemini-cli-sidekick"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "exit",
        "hooks": [
          {
            "name": "end-sidekick-session",
            "type": "command",
            "command": "node ${extensionPath}/scripts/sidekick.ts gemini-cli-sidekick"
          }
        ]
      }
    ]
  }
}
